1  FOR X = 0 TO 24: READ D: POKE 768 + X,D: NEXT : HGR2 : POKE 232,0: POKE 233,3: HCOLOR= 3: SCALE= 1: ROT= 0: DEF  FN A(Y) =  INT( RND(1) * Y * 50):Y = 9: DRAW 1 AT X,Y:I = 99:J = 99: DRAW 2 AT I,J: DATA 2,0,6,0,9,0,46,60,0,41,21,63,87,173,243,19,45,45,213,27,54,246,106,5,0
2  XDRAW 2 AT I,J:I = I +  SGN(X - I):J = J +  SGN(Y - J): DRAW 2 AT I,J: ON  ABS(I - X) > 9 OR  ABS(J - Y) > 15 GOTO 2: XDRAW 1 AT X,Y: FOR Z = 0 TO 1:X =  FN A(5):Y =  FN A(3):Z =  ABS(X - I) > 9 AND  ABS(Y - J) > 9: NEXT : DRAW 1 AT X,Y: GOTO 2